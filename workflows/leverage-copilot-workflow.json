    {
      "parameters": {
        "jsCode": "const secret = $env.LEVERAGE_COPILOT_SECRET;\nif (secret) {\n  const header = $getWebhookHeader('x-leverage-secret') ?? '';\n  if (header !== secret) throw new Error('Unauthorized: missing or invalid x-leverage-secret header');\n}\nreturn $json;"
      },
      "id": "check-auth-0000-0000-000000000000",
      "name": "Check Auth",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

      "id": "aca84a7e-8da0-4650-a023-f1a9f1a64791",
      "name": "Read documents file",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        20,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binKey = Object.keys(item.binary || {})[0] || 'data';\nconst buffer = await this.helpers.getBinaryDataBuffer(0, binKey);\nconst text = buffer.toString('utf8');\nconst docs = JSON.parse(text);\nreturn docs.map((d) => ({\n  json: {\n    text: d.pageContent,\n    metadata: d.metadata,\n  },\n}));"
      },
      "id": "d90655e3-1dfc-4cdb-b3b8-2e456c35276a",

        "jsCode": "const rows = $input.all().map((i) => i.json);\nrows.sort((a, b) => (b.leverage ?? 0) - (a.leverage ?? 0));\nconst top = rows.slice(0, 25);\nconst badge = (r) => (r.kind === 'pr' || String(r.url || '').includes('/pull/')) ? '[PR]' : '[issue]';\nconst md = top\n  .map((r) => `\u2022 ${badge(r)} #${r.number} (leverage ${r.leverage}, \ud83d\udc4d${r.reactions}, \ud83d\udcac${r.comments})\\n  ${r.title}\\n  ${r.url}`)\n  .join('\\n\\n');\nreturn [{ json: { response: `Top ${top.length} n8n open issues by leverage:\\n\\n${md}` } }];"
      },

# Discord bot token (Discord Developer Portal -> your app -> Bot -> Reset Token)
DISCORD_BOT_TOKEN=

# ID of the #copilot channel (Discord: right-click channel -> Copy Channel ID; requires Developer Mode)
COPILOT_CHANNEL_ID=

# n8n Copilot Router webhook. From the bot container use n8n's internal hostname, e.g.
#   http://n8n:5678/webhook/copilot
N8N_WEBHOOK_URL=http://localhost:5678/webhook/leverage-copilot

# Must match LEVERAGE_COPILOT_SECRET set on the n8n container (sent as x-leverage-secret)
LEVERAGE_COPILOT_SECRET=

# Optional: client timeout in ms (default 90000, wide enough for the ~46s ranking run)
REQUEST_TIMEOUT_MS=90000
